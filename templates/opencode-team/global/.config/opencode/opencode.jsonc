{
  "$schema": "https://opencode.ai/config.json",

  "default_agent": "orchestrator",

  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",

      "git status*": "allow",
      "git diff*": "allow",
      "git diff --stat*": "allow",
      "git log*": "allow",

      "rg *": "allow",
      "grep *": "allow",

      "git commit*": "deny",
      "git push*": "deny",
      "git reset --hard*": "deny",
      "git clean*": "deny",

      "rm -rf *": "deny",
      "del /s *": "deny",
      "Remove-Item * -Recurse*": "deny"
    }
  }
}
