{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orchestrator",
  "permission": {
    "edit": {
      "*": "deny",
      "migration/**": "allow",
      "migration/scripts/check-scope.ps1": "deny",
      "migration/scripts/check-final-gate.ps1": "deny",
      "migration/scripts/check-harness-policy.ps1": "deny",
      "migration/.migration-kit/guard-checksums.json": "deny",
      "migration/state/harness-policy.json": "deny"
    },
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git diff --stat*": "allow",
      "git log*": "allow",
      "rg *": "allow",
      "grep *": "allow",
      "Get-Content *": "allow",
      "Test-Path *": "allow",
      "Get-ChildItem *": "allow",
      "Select-String *": "allow",
      "ConvertFrom-Json*": "allow",
      "Out-Null": "allow",
      "dotnet build*": "allow",
      "dotnet test*": "allow",
      "dotnet tool run selenium-pw-migrator *": "allow",
      "selenium-pw-migrator *": "allow",
      "pwsh *check-scope.ps1*": "allow",
      "pwsh *check-final-gate.ps1*": "allow",
      "pwsh *check-harness-policy.ps1*": "allow",
      "powershell *check-scope.ps1*": "allow",
      "powershell *check-final-gate.ps1*": "allow",
      "powershell *check-harness-policy.ps1*": "allow",
      "python *": "ask",
      "py *": "ask",
      "powershell *": "ask",
      "pwsh *": "ask",
      "cmd /c *": "ask",
      "cp *": "ask",
      "copy *": "ask",
      "Copy-Item *": "ask",
      "mv *": "ask",
      "Move-Item *": "ask",
      "Set-Content *": "ask",
      "Out-File *": "ask",
      "New-Item *": "ask",
      "git commit*": "deny",
      "git push*": "deny",
      "git reset --hard*": "deny",
      "git clean*": "deny",
      "rm -rf *": "deny",
      "del /s *": "deny",
      "Remove-Item * -Recurse*": "deny"
    },
    "task": {
      "*": "deny",
      "orchestrator": "allow",
      "watchdog": "allow",
      "reviewer": "allow",
      "executor": "ask",
      "general": "deny"
    },
    "question": "ask",
    "external_directory": "ask",
    "doom_loop": "ask"
  }
}
