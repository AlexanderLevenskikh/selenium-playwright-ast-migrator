{
  "$schema": "https://opencode.ai/config.json",

  "default_agent": "orchestrator",

  "permission": {
    "edit": {
      "*": "deny",
      "migration/**": "allow"
    },
    "bash": {
      "*": "ask",

      "git status*": "allow",
      "git diff*": "allow",
      "git diff --stat*": "allow",
      "git log*": "allow",

      "rg *": "allow",
      "grep *": "allow",

      "python *": "ask",
      "py *": "ask",
      "powershell *": "ask",
      "pwsh *": "ask",
      "cmd /c *": "ask",
      "cp *": "ask",
      "copy *": "ask",
      "Copy-Item *": "ask",
      "mv *": "ask",
      "Move-Item *": "ask",
      "Set-Content *": "ask",
      "Out-File *": "ask",
      "New-Item *": "ask",

      "git commit*": "deny",
      "git push*": "deny",
      "git reset --hard*": "deny",
      "git clean*": "deny",

      "rm -rf *": "deny",
      "del /s *": "deny",
      "Remove-Item * -Recurse*": "deny"
    },
    "task": {
      "*": "deny",
      "orchestrator": "allow",
      "watchdog": "allow",
      "reviewer": "allow",
      "executor": "ask",
      "general": "deny"
    },
    "question": "ask",
    "external_directory": "ask",
    "doom_loop": "ask"
  }
}
