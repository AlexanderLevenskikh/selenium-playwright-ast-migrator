{
  // Reference patch for less noisy autopilot runs.
  // Merge these entries into templates/opencode-team/global/.config/opencode/opencode.jsonc
  // and into project-local opencode.jsonc produced by install-windows.ps1.
  // Keep the existing deny defaults.
  "permission": {
    "edit": {
      "*": "deny",
      "migration/**": "allow",
      "migration/scripts/check-scope.ps1": "deny",
      "migration/scripts/check-final-gate.ps1": "deny",
      "migration/scripts/check-harness-policy.ps1": "deny",
      "migration/.migration-kit/guard-checksums.json": "deny",
      "opencode.jsonc": "deny",
      ".opencode/**": "deny",
      ".opencode-migrator/**": "deny",
      "AGENTS.md": "deny"
    },
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git diff --stat*": "allow",
      "git log*": "allow",
      "rg *": "allow",
      "grep *": "allow",
      "dotnet build*": "allow",
      "dotnet test*": "allow",
      "dotnet run --project Migrator.Cli*": "allow",
      "selenium-pw-migrator *": "allow",
      "dotnet tool run selenium-pw-migrator *": "allow",
      "pwsh -NoProfile -ExecutionPolicy Bypass -File migration/scripts/check-scope.ps1*": "allow",
      "pwsh -NoProfile -ExecutionPolicy Bypass -File migration/scripts/check-final-gate.ps1*": "allow",
      "pwsh -NoProfile -ExecutionPolicy Bypass -File migration/scripts/check-harness-policy.ps1*": "allow",
      "powershell -NoProfile -ExecutionPolicy Bypass -File migration/scripts/check-scope.ps1*": "allow",
      "powershell -NoProfile -ExecutionPolicy Bypass -File migration/scripts/check-final-gate.ps1*": "allow",
      "powershell -NoProfile -ExecutionPolicy Bypass -File migration/scripts/check-harness-policy.ps1*": "allow",
      "python *": "ask",
      "py *": "ask",
      "powershell *": "ask",
      "pwsh *": "ask",
      "cmd /c *": "ask",
      "Copy-Item *": "ask",
      "Move-Item *": "ask",
      "Set-Content *": "ask",
      "Out-File *": "ask",
      "New-Item *": "ask",
      "npm *": "ask",
      "yarn *": "ask",
      "pnpm *": "ask",
      "curl *": "ask",
      "Invoke-WebRequest *": "ask",
      "git commit*": "deny",
      "git push*": "deny",
      "git reset --hard*": "deny",
      "git clean*": "deny",
      "rm -rf *": "deny",
      "del /s *": "deny",
      "Remove-Item * -Recurse*": "deny"
    },
    "task": {
      "*": "deny",
      "orchestrator": "allow",
      "watchdog": "allow",
      "reviewer": "allow",
      "executor": "allow",
      "general": "deny"
    },
    "question": "ask",
    "external_directory": "ask",
    "doom_loop": "ask"
  }
}
