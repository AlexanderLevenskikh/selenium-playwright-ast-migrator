{
  "schemaVersion": "migration-agent-skills/v2",
  "description": "Reusable behavior contracts for the standard full-project migration flow. Skills guide agents but never grant permissions.",
  "coreSkills": [
    {
      "name": "plow-ahead",
      "path": "agent-skills/plow-ahead/SKILL.md",
      "requiredFor": [
        "bounded standard-run continuation",
        "routine ambiguity"
      ]
    },
    {
      "name": "read-the-damn-docs",
      "path": "agent-skills/read-the-damn-docs/SKILL.md",
      "requiredFor": [
        "dependency/API/SDK/CLI/framework/browser/CI/auth changes"
      ]
    },
    {
      "name": "agent-watchdog",
      "path": "agent-skills/agent-watchdog/SKILL.md",
      "requiredFor": [
        "evidence audit",
        "handoff review"
      ]
    },
    {
      "name": "efficient-frontier",
      "path": "agent-skills/efficient-frontier/SKILL.md",
      "requiredFor": [
        "broad TODO/log decomposition"
      ]
    },
    {
      "name": "quick-recap",
      "path": "agent-skills/quick-recap/SKILL.md",
      "requiredFor": [
        "user-facing handoff"
      ]
    },
    {
      "name": "plan-arbiter",
      "path": "agent-skills/plan-arbiter/SKILL.md",
      "requiredFor": [
        "competing plans"
      ]
    },
    {
      "name": "root-cause-prioritization",
      "path": "agent-skills/root-cause-prioritization/SKILL.md",
      "requiredFor": [
        "TODO root/cascade analysis",
        "high-leverage remediation selection"
      ]
    }
  ],
  "usageLedger": {
    "schemaVersion": "agent-skill-usage/v1",
    "global": "state/agent-skill-usage.jsonl",
    "perRun": "runs/<run-id>/skills/agent-skill-usage.jsonl",
    "humanSummary": "runs/<run-id>/skills/applied-skills.md",
    "writer": "scripts/write-agent-skill-usage.ps1",
    "profileRecorder": "scripts/record-agent-skill-profile.ps1",
    "optional": true,
    "acceptanceEvidence": false
  },
  "invariants": [
    "Skills never override AGENT_CONTRACT.md, the standard-run policy, scope guard, OpenCode permissions, project verification, or final gate.",
    "Skills must not create hidden execution batches or more than one active write task before a full rerun.",
    "Skill-use logging is optional diagnostics and is never acceptance evidence.",
    "Final handoff must cite real status and evidence."
  ],
  "recommendedProfiles": [
    {
      "name": "orchestrator",
      "skills": [
        "plow-ahead",
        "efficient-frontier",
        "root-cause-prioritization",
        "quick-recap"
      ],
      "useWhen": "planning or resuming a standard run"
    },
    {
      "name": "supervised-task",
      "skills": [
        "plow-ahead",
        "efficient-frontier",
        "root-cause-prioritization",
        "quick-recap"
      ],
      "useWhen": "handling /supervised-task dispatch"
    },
    {
      "name": "executor",
      "skills": [
        "plow-ahead"
      ],
      "useWhen": "implementing a bounded task"
    },
    {
      "name": "executor-docs-first",
      "skills": [
        "plow-ahead",
        "read-the-damn-docs"
      ],
      "useWhen": "implementation touches external behavior"
    },
    {
      "name": "watchdog",
      "skills": [
        "agent-watchdog"
      ],
      "useWhen": "auditing results and evidence"
    },
    {
      "name": "reviewer",
      "skills": [
        "agent-watchdog",
        "quick-recap"
      ],
      "useWhen": "reviewing a diff and verification"
    },
    {
      "name": "plan-arbiter",
      "skills": [
        "plan-arbiter"
      ],
      "useWhen": "comparing plans"
    },
    {
      "name": "final-handoff",
      "skills": [
        "quick-recap"
      ],
      "useWhen": "preparing final handoff"
    }
  ]
}
