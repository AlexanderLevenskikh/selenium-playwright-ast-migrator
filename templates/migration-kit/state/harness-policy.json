{
  "$schema": "https://example.local/migrator-agent-harness-policy.schema.json",
  "schemaVersion": 1,
  "name": "Migrator artifact-only autopilot policy",
  "mode": "artifact-only",
  "defaultWriteDecision": "deny",
  "defaultShellDecision": "allow",
  "allowedWrites": [
    "migration/**"
  ],
  "guardSensitiveWrites": [
    "migration/scripts/check-scope.ps1",
    "migration/scripts/check-final-gate.ps1",
    "migration/scripts/check-harness-policy.ps1",
    "migration/.migration-kit/guard-checksums.json",
    "opencode.jsonc",
    ".opencode/**",
    ".opencode-migrator/**",
    "AGENTS.md",
    "migration/scripts/check-scope.sh",
    "migration/scripts/check-final-gate.sh",
    "migration/scripts/check-harness-policy.sh"
  ],
  "deniedWrites": [
    ".git/**",
    "**/.env",
    "**/.env.*",
    "**/secrets/**",
    "**/*secret*",
    "**/*token*",
    "**/nuget.config",
    "**/*.csproj",
    "**/*.sln",
    "**/package.json",
    "**/yarn.lock",
    "**/package-lock.json",
    "**/pnpm-lock.yaml"
  ],
  "allowedCommands": [
    "git status*",
    "git diff*",
    "git diff --stat*",
    "git log*",
    "rg *",
    "grep *",
    "Get-Content *",
    "Get-Content*",
    "Test-Path *",
    "Test-Path*",
    "Get-ChildItem *",
    "Get-ChildItem*",
    "Select-String *",
    "Select-String*",
    "Select-Object*",
    "Resolve-Path*",
    "ConvertFrom-Json*",
    "Out-Null",
    "dotnet build*",
    "dotnet test*",
    "dotnet run --project Migrator.Cli*",
    "selenium-pw-migrator *",
    "dotnet tool run selenium-pw-migrator *",
    "pwsh *new-harness-run.ps1*",
    "pwsh *write-harness-event.ps1*",
    "pwsh *build-harness-dashboard.ps1*",
    "pwsh *check-scope.ps1*",
    "pwsh *check-final-gate.ps1*",
    "pwsh *check-harness-policy.ps1*",
    "powershell *new-harness-run.ps1*",
    "powershell *write-harness-event.ps1*",
    "powershell *build-harness-dashboard.ps1*",
    "powershell *check-scope.ps1*",
    "powershell *check-final-gate.ps1*",
    "powershell *check-harness-policy.ps1*",
    "pwsh -NoProfile -ExecutionPolicy Bypass -File migration/scripts/new-harness-run.ps1*",
    "pwsh -NoProfile -ExecutionPolicy Bypass -File migration/scripts/write-harness-event.ps1*",
    "pwsh -NoProfile -ExecutionPolicy Bypass -File migration/scripts/build-harness-dashboard.ps1*",
    "pwsh -NoProfile -ExecutionPolicy Bypass -File migration/scripts/check-scope.ps1*",
    "pwsh -NoProfile -ExecutionPolicy Bypass -File migration/scripts/check-final-gate.ps1*",
    "pwsh -NoProfile -ExecutionPolicy Bypass -File migration/scripts/check-harness-policy.ps1*",
    "powershell -NoProfile -ExecutionPolicy Bypass -File migration/scripts/new-harness-run.ps1*",
    "powershell -NoProfile -ExecutionPolicy Bypass -File migration/scripts/write-harness-event.ps1*",
    "powershell -NoProfile -ExecutionPolicy Bypass -File migration/scripts/build-harness-dashboard.ps1*",
    "powershell -NoProfile -ExecutionPolicy Bypass -File migration/scripts/check-scope.ps1*",
    "powershell -NoProfile -ExecutionPolicy Bypass -File migration/scripts/check-final-gate.ps1*",
    "powershell -NoProfile -ExecutionPolicy Bypass -File migration/scripts/check-harness-policy.ps1*",
    "./migration/scripts/new-harness-run.ps1*",
    ".\\migration\\scripts\\new-harness-run.ps1*",
    "./migration/scripts/write-harness-event.ps1*",
    ".\\migration\\scripts\\write-harness-event.ps1*",
    "./migration/scripts/build-harness-dashboard.ps1*",
    ".\\migration\\scripts\\build-harness-dashboard.ps1*",
    "./migration/scripts/check-scope.ps1*",
    ".\\migration\\scripts\\check-scope.ps1*",
    "./migration/scripts/check-final-gate.ps1*",
    ".\\migration\\scripts\\check-final-gate.ps1*",
    "./migration/scripts/check-harness-policy.ps1*",
    ".\\migration\\scripts\\check-harness-policy.ps1*",
    "./migration/scripts/check-scope.sh*",
    "./migration/scripts/check-final-gate.sh*",
    "./migration/scripts/check-harness-policy.sh*",
    "./migration/scripts/new-harness-run.sh*",
    "./migration/scripts/write-harness-event.sh*",
    "./migration/scripts/build-harness-dashboard.sh*",
    "bash migration/scripts/check-scope.sh*",
    "bash migration/scripts/check-final-gate.sh*",
    "bash migration/scripts/check-harness-policy.sh*",
    "bash migration/scripts/new-harness-run.sh*",
    "bash migration/scripts/write-harness-event.sh*",
    "bash migration/scripts/build-harness-dashboard.sh*",
    "migration/scripts/check-scope.sh*",
    "bash ./migration/scripts/check-scope.sh*",
    "migration/scripts/check-final-gate.sh*",
    "bash ./migration/scripts/check-final-gate.sh*",
    "migration/scripts/check-harness-policy.sh*",
    "bash ./migration/scripts/check-harness-policy.sh*",
    "migration/scripts/new-harness-run.sh*",
    "bash ./migration/scripts/new-harness-run.sh*",
    "migration/scripts/write-harness-event.sh*",
    "bash ./migration/scripts/write-harness-event.sh*",
    "migration/scripts/build-harness-dashboard.sh*",
    "bash ./migration/scripts/build-harness-dashboard.sh*"
  ],
  "deniedCommands": [
    "git commit*",
    "git push*",
    "git reset --hard*",
    "git clean*",
    "git checkout*",
    "git restore *",
    "git switch *",
    "git branch -D*",
    "git branch -d*",
    "rm -rf *",
    "rm -r *",
    "del /s *",
    "rmdir /s *",
    "Remove-Item * -Recurse*",
    "Remove-Item -Recurse *",
    "format *",
    "diskpart*",
    "reg delete*",
    "Set-ExecutionPolicy*",
    "curl *",
    "wget *",
    "Invoke-WebRequest *",
    "iwr *",
    "Invoke-RestMethod *",
    "irm *",
    "npm publish*",
    "yarn publish*",
    "pnpm publish*",
    "dotnet nuget push*",
    "nuget push*"
  ],
  "autopilot": {
    "statusWhenHealthy": "CONTINUE_AUTONOMOUSLY",
    "maxSelfRepairCyclesPerBatch": 3,
    "doNotAskFor": [
      "reading repository files",
      "read-only shell inspection of repository and migration evidence",
      "searching with rg/grep",
      "copying/updating migration run artifacts",
      "running local build/test/verification commands",
      "running scope/final/harness checks",
      "local PowerShell/bash/Python helper commands inside the workspace"
    ],
    "stopFor": [
      "writes outside allowed roots",
      "guard or permission changes",
      "real product project edits in artifact-only mode",
      "external-directory access",
      "network fetch/search commands",
      "git commit/push/checkout/reset/clean",
      "destructive delete/move",
      "package publishing"
    ],
    "successCheckpoint": {
      "defaultAfterFinal": "STOP_FOR_REVIEW",
      "zeroArgumentAfterFinal": "REPORT_STATUS_AND_RECOMMENDED_CONTINUE_COMMAND",
      "continueRequires": "plain explicit /supervised-task continue starts post-final research; implementation needs reviewed research, a concrete implementation task, or bounded autoContinuation",
      "plainContinueAfterFinal": "POST_FINAL_RESEARCH",
      "postFinalResearchAgent": "migration-researcher",
      "postFinalReviewAgent": "migration-change-reviewer",
      "forbidSilentNextRunAfterFinal": true
    }
  },
  "requiredFiles": [
    "AGENT_CONTRACT.md",
    "agent-state.md",
    "current-ticket.md",
    "state/harness-policy.json",
    "state/run-ledger.md",
    "state/handoff.md",
    "scripts/check-scope.ps1",
    "scripts/check-final-gate.ps1",
    "harness/README.md",
    "state/harness-run-template.json",
    "prompts/autopilot-loop-prompt.txt",
    "prompts/harness-review-prompt.txt",
    "scripts/new-harness-run.ps1",
    "scripts/write-harness-event.ps1",
    "scripts/check-harness-policy.ps1",
    "scripts/check-scope.sh",
    "scripts/check-final-gate.sh",
    "scripts/check-harness-policy.sh",
    "scripts/new-harness-run.sh",
    "scripts/write-harness-event.sh",
    "scripts/build-harness-dashboard.sh"
  ],
  "finalGate": {
    "script": "scripts/check-final-gate.ps1",
    "requiredBeforeFinalAnswer": true,
    "finalStatusFile": "state/final-gate-result.json",
    "shellWrapper": "scripts/check-final-gate.sh"
  }
}
