  "autopilot": {
    "safeReadCommands": true,
    "safeScopedTestCommands": true,
    "safeMigrationStateWrites": true,
    "dangerousDestructiveCommands": "forbidden",
    "outOfScopeWrites": "forbidden",
    "dependencyInstall": "review-required",
    "networkAccess": "review-required",
    "statusWhenHealthy": "CONTINUE_AUTONOMOUSLY",
    "maxSelfRepairCyclesPerBatch": 3,
    "doNotAskFor": [
      "reading repository files",
      "read-only shell inspection of repository and migration evidence",
      "searching with rg/grep",
      "copying/updating migration run artifacts",
      "running local build/test/verification commands",
      "running scope/final/harness checks",
      "local PowerShell/bash/Python helper commands inside the workspace"
    ],
    "stopFor": [
      "writes outside allowed roots",
      "guard or permission changes",
      "real product project edits in artifact-only mode",
      "external-directory access",
      "network fetch/search commands",
      "git commit/push/checkout/reset/clean",
      "destructive delete/move",
      "package publishing"
    ],
    "successCheckpoint": {
      "defaultAfterFinal": "STOP_FOR_REVIEW",
      "zeroArgumentAfterFinal": "REPORT_STATUS_FOR_FRESH_FINAL_ONLY; RESUME_POST_FINAL_LOOP_WHEN_STATUS_ALREADY_FINAL_STOPPED_FOR_REVIEW",
      "continueRequires": "persisted FINAL_STOPPED_FOR_REVIEW starts or resumes the post-final loop on zero-argument /supervised-task or explicit /supervised-task continue: existing current-ticket/backlog -> change-reviewer -> executor; approved research -> task-slicer; existing research -> research-lead; otherwise researcher. One bounded executor task under migration/** is allowed unless reviewer/policy blocks it.",
      "plainContinueAfterFinal": "RESUME_OR_START_POST_FINAL_LOOP",
      "zeroArgumentWhenFinalStoppedForReview": "RESUME_OR_START_POST_FINAL_LOOP",
      "postFinalWorkflow": [
        "POST_FINAL_RESEARCH",
        "REVIEW_POST_FINAL_RESEARCH_WITH_RESEARCH_LEAD",
        "SLICE_RESEARCH_INTO_BOUNDED_TASKS",
        "RUN_NEXT_BOUNDED_TASK"
      ],
      "postFinalResearchAgent": "migration-researcher",
      "postFinalResearchLeadAgent": "migration-research-lead",
      "postFinalTaskSlicerAgent": "migration-task-slicer",
      "postFinalReviewAgent": "migration-change-reviewer",
      "forbidSilentNextRunAfterFinal": true,
      "postFinalDispatch": "existing current-ticket/backlog -> change-reviewer -> executor; approved research -> task-slicer; existing research -> research-lead; otherwise researcher",
      "forbidNoWorkReportAfterContinue": true,
      "postFinalStopRule": "No no-work terminal report after persisted FINAL_STOPPED_FOR_REVIEW dispatch until task-slicer writes BLOCKED_NO_AGENT_EXECUTABLE_TASKS or change-reviewer writes a concrete blocker."
    },
    "safeEvidenceWrites": true,
    "safeClaimRecovery": "review-required",
    "commandClassifier": "scripts/evaluate-command-policy.ps1"
  },
