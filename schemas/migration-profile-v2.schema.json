{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/selenium-playwright-ast-migrator/migration-profile-v2.schema.json",
  "title": "Migrator migration-profile v2",
  "description": "Experimental normalized source/target/project profile schema. Legacy adapter-config.json can be normalized into this shape without losing data.",
  "type": "object",
  "additionalProperties": true,
  "required": ["Source", "Target", "Project"],
  "properties": {
    "SchemaVersion": { "type": "string", "const": "migration-profile/v2" },
    "SourceProjectName": { "type": "string" },
    "Source": {
      "type": "object",
      "additionalProperties": true,
      "required": ["Id", "Language", "Framework"],
      "properties": {
        "Id": { "type": "string", "examples": ["selenium-csharp", "selenium-java", "selenium-python"] },
        "Language": { "type": "string", "examples": ["csharp", "java", "python"] },
        "Framework": { "type": "string", "examples": ["selenium"] },
        "SourceOnlyIdentifiers": { "type": "array", "items": { "type": "string" } },
        "SuppressedMethods": { "type": "array", "items": { "type": "string" } },
        "SuppressedMethodPatterns": { "type": "array", "items": { "type": "string" } },
        "RecognizerAliases": { "type": "object" },
        "GenericResultMethods": { "type": "array", "items": { "type": "string" } },
        "WaitPolicies": { "type": "array", "items": { "type": "object" } }
      }
    },
    "Target": {
      "type": "object",
      "additionalProperties": true,
      "required": ["Id", "Language", "Framework"],
      "properties": {
        "Id": { "type": "string", "examples": ["playwright-dotnet", "playwright-typescript"] },
        "Language": { "type": "string", "examples": ["csharp", "typescript"] },
        "Framework": { "type": "string", "examples": ["playwright"] },
        "TargetKnownTypes": { "type": "array", "items": { "type": "string" } },
        "TargetKnownIdentifiers": { "type": "array", "items": { "type": "string" } },
        "TestHost": { "type": "object" },
        "LocatorSettings": { "type": "object" },
        "TargetStatementDefaults": { "type": "object" }
      }
    },
    "Project": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "UiTargets": { "type": "array", "items": { "type": "object" } },
        "PageObjects": { "type": "array", "items": { "type": "object" } },
        "Methods": { "type": "array", "items": { "type": "object" } },
        "ParameterizedMethods": { "type": "array", "items": { "type": "object" } },
        "Tables": { "type": "array", "items": { "type": "object" } },
        "Pagination": { "type": "array", "items": { "type": "object" } },
        "NavigationUrls": { "type": "object", "additionalProperties": { "type": "string" } },
        "Scopes": { "type": "array", "items": { "type": "object" } },
        "QualityGates": { "type": "object" },
        "Verification": { "type": "object" }
      }
    },
    "LegacyConfig": {
      "type": "object",
      "description": "Optional copy of the original adapter-config v1 for lossless round-tripping during migration."
    }
  }
}
