{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/selenium-playwright-ast-migrator/adapter-config.schema.json",
  "title": "Selenium Playwright AST Migrator adapter-config",
  "description": "Config/profile schema for Selenium C# -> Playwright .NET AST Migrator. Project-specific migration knowledge belongs here; renderer code should stay generic.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional editor schema hint. Use ./schemas/adapter-config.schema.json in local repos."
    },
    "SourceProjectName": {
      "type": "string",
      "description": "Human-readable project/profile name."
    },
    "SourceOnlyIdentifiers": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true,
      "description": "Source/Selenium-only roots that must not be rendered as active target code, e.g. page, pagef, Driver, WebDriver."
    },
    "TargetKnownTypes": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true,
      "description": "Target-side type names available in generated code, e.g. Product, Navigation. Do not put source-only roots here."
    },
    "TargetKnownIdentifiers": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true,
      "description": "Target-side identifiers available in generated code. Use sparingly."
    },
    "UiTargets": {
      "type": "array",
      "items": { "$ref": "#/$defs/uiTarget" },
      "description": "Maps source POM expressions to Playwright locators."
    },
    "PageObjects": {
      "type": "array",
      "items": { "$ref": "#/$defs/pageObject" }
    },
    "Methods": {
      "type": "array",
      "items": { "$ref": "#/$defs/methodMapping" },
      "description": "Exact method mappings. ParameterizedMethods are usually preferred for reusable patterns."
    },
    "ParameterizedMethods": {
      "type": "array",
      "items": { "$ref": "#/$defs/parameterizedMethodMapping" },
      "description": "Pattern-based method mappings with {placeholder} support."
    },
    "LocatorSettings": { "$ref": "#/$defs/locatorSettings" },
    "TestHost": { "$ref": "#/$defs/testHost" },
    "Verification": { "$ref": "#/$defs/verification" },
    "QualityGates": { "$ref": "#/$defs/qualityGates" },
    "Tables": {
      "type": "array",
      "items": { "$ref": "#/$defs/table" }
    },
    "Pagination": {
      "type": "array",
      "items": { "$ref": "#/$defs/pagination" }
    },
    "Scopes": {
      "type": "array",
      "items": { "$ref": "#/$defs/scope" },
      "description": "Per-file/per-suite profile overrides."
    }
  },
  "$defs": {
    "targetKind": {
      "type": "string",
      "enum": ["TestId", "Text", "Css", "XPath", "RawExpression", "Unresolved"],
      "description": "Target locator strategy. Prefer TestId; RawExpression is a last resort."
    },
    "uiTarget": {
      "type": "object",
      "additionalProperties": true,
      "required": ["SourceExpression", "TargetExpression", "TargetKind"],
      "properties": {
        "SourceExpression": { "type": "string" },
        "TargetExpression": { "type": "string" },
        "TargetKind": { "$ref": "#/$defs/targetKind" },
        "TestIdAttribute": { "type": "string" },
        "Match": { "type": "string", "enum": ["First", "Nth"] },
        "Index": { "type": "integer", "minimum": 0 },
        "SourceTruth": { "type": "string", "description": "Optional agent note: file/line or POM source that proves the mapping." },
        "Confidence": { "type": "string", "enum": ["high", "medium", "low"] },
        "RequiresReview": { "type": "boolean" }
      }
    },
    "pageObject": {
      "type": "object",
      "additionalProperties": true,
      "required": ["SourceType", "TargetType", "VariableName", "ConstructorStrategy"],
      "properties": {
        "SourceType": { "type": "string" },
        "TargetType": { "type": "string" },
        "VariableName": { "type": "string" },
        "ConstructorStrategy": { "type": "string" }
      }
    },
    "methodMapping": {
      "type": "object",
      "additionalProperties": true,
      "required": ["SourceMethod"],
      "properties": {
        "SourceMethod": { "type": "string" },
        "TargetMethod": { "type": "string" },
        "Description": { "type": "string" },
        "TargetStatements": { "type": "array", "items": { "type": "string" } },
        "RequiresReview": { "type": "boolean" },
        "SourceTruth": { "type": "string" },
        "Confidence": { "type": "string", "enum": ["high", "medium", "low"] }
      }
    },
    "parameterizedMethodMapping": {
      "type": "object",
      "additionalProperties": true,
      "required": ["SourceMethodPattern"],
      "properties": {
        "SourceMethodPattern": { "type": "string", "description": "Use {placeholderName} tokens in method arguments/receiver." },
        "TargetStatements": { "type": "array", "items": { "type": "string" } },
        "RequiresReview": { "type": "boolean" },
        "Description": { "type": "string" },
        "SourceTruth": { "type": "string" },
        "Confidence": { "type": "string", "enum": ["high", "medium", "low"] }
      }
    },
    "locatorSettings": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "DefaultTestIdAttribute": { "type": "string" },
        "KnownTestIdAttributes": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      }
    },
    "testHost": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "Namespace": { "type": "string" },
        "BaseClass": { "type": "string" },
        "ClassAttributes": { "type": "array", "items": { "type": "string" } },
        "Usings": { "type": "array", "items": { "type": "string" } },
        "SetUpStatements": { "type": "array", "items": { "type": "string" } },
        "ClassName": { "type": "string" }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "TargetFramework": { "type": "string" },
        "BaseDirectory": { "type": "string" },
        "Solution": { "type": "string" },
        "BuildWorkingDirectory": { "type": "string" },
        "ProjectReferences": { "type": "array", "items": { "type": "string" } },
        "PackageReferences": { "type": "array", "items": { "$ref": "#/$defs/packageReference" } },
        "AssemblyReferences": { "type": "array", "items": { "type": "string" } },
        "DisableDefaultPackageReferences": { "type": "boolean" },
        "AutoDiscoverNearestProject": { "type": "boolean" },
        "AutoDiscoverProjectReferences": { "type": "boolean" },
        "AutoDiscoverBuildFiles": { "type": "boolean" },
        "AutoDiscoverPackageReferences": { "type": "boolean" },
        "NoRestore": { "type": "boolean" },
        "Configuration": { "type": "string" },
        "RuntimeIdentifier": { "type": "string" }
      }
    },
    "packageReference": {
      "type": "object",
      "additionalProperties": true,
      "required": ["Include"],
      "properties": {
        "Include": { "type": "string" },
        "Version": { "type": "string" }
      }
    },
    "qualityGates": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "MaxTodoComments": { "type": "integer", "minimum": 0 },
        "MaxUnsupportedActions": { "type": "integer", "minimum": 0 },
        "MaxUnmappedTargets": { "type": "integer", "minimum": 0 },
        "MaxRawExpressions": { "type": "integer", "minimum": 0 },
        "FailOnPageTodo": { "type": "boolean" },
        "FailOnSyntaxErrors": { "type": "boolean" },
        "FailOnProjectVerifyErrors": { "type": "boolean" }
      }
    },
    "targetMappingEntry": {
      "type": "object",
      "additionalProperties": true,
      "required": ["TargetExpression"],
      "properties": {
        "TargetExpression": { "type": "string" },
        "TargetKind": { "$ref": "#/$defs/targetKind" },
        "TestIdAttribute": { "type": "string" }
      }
    },
    "table": {
      "type": "object",
      "additionalProperties": true,
      "required": ["SourceExpression"],
      "properties": {
        "SourceExpression": { "type": "string" },
        "RowTarget": { "$ref": "#/$defs/targetMappingEntry" },
        "Pagination": { "$ref": "#/$defs/paginationEntry" }
      }
    },
    "paginationEntry": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "Forward": { "$ref": "#/$defs/targetMappingEntry" }
      }
    },
    "pagination": {
      "type": "object",
      "additionalProperties": true,
      "required": ["SourceExpression", "TargetExpression"],
      "properties": {
        "SourceExpression": { "type": "string" },
        "TargetExpression": { "type": "string" },
        "TargetKind": { "$ref": "#/$defs/targetKind" },
        "TestIdAttribute": { "type": "string" }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": true,
      "required": ["Name"],
      "properties": {
        "Name": { "type": "string" },
        "SourcePathPatterns": { "type": "array", "items": { "type": "string" } },
        "TestHost": { "$ref": "#/$defs/testHost" },
        "UiTargets": { "type": "array", "items": { "$ref": "#/$defs/uiTarget" } },
        "Methods": { "type": "array", "items": { "$ref": "#/$defs/methodMapping" } },
        "ParameterizedMethods": { "type": "array", "items": { "$ref": "#/$defs/parameterizedMethodMapping" } },
        "TargetKnownTypes": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "TargetKnownIdentifiers": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "Tables": { "type": "array", "items": { "$ref": "#/$defs/table" } },
        "Pagination": { "type": "array", "items": { "$ref": "#/$defs/pagination" } }
      }
    }
  }
}
