{
  "$schema": "../../schemas/adapter-config.schema.json",
  "SchemaVersion": "adapter-config/v1",
  "SourceProjectName": "PublicLaunchDemo.SeleniumTests",
  "UiTargets": [
    {
      "SourceExpression": "page.Username",
      "TargetExpression": "GetByTestId(\"login-username\")",
      "TargetKind": "TestId"
    },
    {
      "SourceExpression": "page.Password",
      "TargetExpression": "GetByTestId(\"login-password\")",
      "TargetKind": "TestId"
    },
    {
      "SourceExpression": "page.SubmitButton",
      "TargetExpression": "GetByRole(AriaRole.Button, new() { Name = \"Sign in\" })",
      "TargetKind": "Role"
    },
    {
      "SourceExpression": "page.Toast",
      "TargetExpression": "GetByTestId(\"login-success-toast\")",
      "TargetKind": "TestId"
    }
  ],
  "PageObjects": [],
  "Methods": []
}
