{
  "$schema": "../schemas/adapter-config.schema.json",
  "SourceProjectName": "ExampleTestProject",
  "SourceOnlyIdentifiers": [
    "page",
    "pagef",
    "Driver",
    "WebDriver"
  ],
  "TargetKnownTypes": [
    "Product",
    "Navigation"
  ],
  "TargetKnownIdentifiers": [
    "Navigation"
  ],
  "UiTargets": [
    {
      "SourceExpression": "page.User",
      "TargetExpression": "GetByTestId(\"user-filter\")",
      "TargetKind": "TestId"
    },
    {
      "SourceExpression": "page.Name",
      "TargetExpression": "GetByTestId(\"user-name\")",
      "TargetKind": "TestId"
    },
    {
      "SourceExpression": "page.MenuItems.SearchButton",
      "TargetExpression": "GetByTestId(\"search-button\")",
      "TargetKind": "TestId"
    },
    {
      "SourceExpression": "page.MenuItems.Catalogs",
      "TargetExpression": "GetByTestId(\"catalogs-menu\")",
      "TargetKind": "TestId"
    },
    {
      "SourceExpression": "page.MenuItems.Partners",
      "TargetExpression": "GetByTestId(\"partners-menu\")",
      "TargetKind": "TestId"
    },
    {
      "SourceExpression": "page.SearchInput",
      "TargetExpression": "Locator(\"[data-tid='Input__root']\")",
      "TargetKind": "Locator"
    },
    {
      "SourceExpression": "page.Footer",
      "TargetExpression": "GetByTestId(\"process-footer\")",
      "TargetKind": "TestId"
    },
    {
      "SourceExpression": "page.Parameters",
      "TargetExpression": "GetByTestId(\"params-label\")",
      "TargetKind": "TestId"
    }
  ],
  "PageObjects": [],
  "Methods": [
    {
      "SourceMethod": "Navigation.OpenTargetPage()",
      "TargetMethod": null,
      "Description": "Navigate to the target page from setup",
      "TargetStatements": [
        "await Page.GotoAsync(\"/target-page\");"
      ],
      "RequiresReview": false
    },
    {
      "SourceMethod": "page.Loader.ValidateLoading()",
      "TargetMethod": null,
      "Description": "Wait for page loading indicator to complete",
      "TargetStatements": [
        "await Expect(Page.GetByTestId(\"loading-indicator\")).ToBeHiddenAsync();"
      ],
      "RequiresReview": false
    }
  ],
  "Verification": {
    "BaseDirectory": "TODO: path to source repo root",
    "BuildWorkingDirectory": "TODO: path to source repo root",
    "Solution": "TODO: optional/path/to/source.sln",
    "ProjectReferences": [
      "TODO: relative/path/to/source-tests.csproj"
    ],
    "PackageReferences": [
      {
        "Include": "Microsoft.Playwright.NUnit",
        "Version": "1.52.0"
      },
      {
        "Include": "NUnit",
        "Version": "3.14.0"
      }
    ],
    "AutoDiscoverNearestProject": true,
    "AutoDiscoverProjectReferences": true,
    "AutoDiscoverBuildFiles": true,
    "AutoDiscoverPackageReferences": false,
    "NoRestore": false,
    "Configuration": "Debug"
  }
}
